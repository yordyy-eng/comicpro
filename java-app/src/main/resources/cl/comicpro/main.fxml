<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="cl.comicpro.ui.MainController"
            prefWidth="720" prefHeight="560"
            style="-fx-background-color: #1a1a2e;">

    <top>
        <VBox style="-fx-background-color: #16213e; -fx-padding: 16;">
            <Label text="ComicPro Translation Studio"
                   style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #e94560;"/>
            <Label text="JDownloader → Traducción → PDF"
                   style="-fx-font-size: 12; -fx-text-fill: #888;"/>
        </VBox>
    </top>

    <center>
        <VBox spacing="14" style="-fx-padding: 20;">

            <!-- API Settings -->
            <TitledPane text="Configuración Gemini API" collapsible="false"
                        style="-fx-text-fill: white; -fx-base: #0f3460;">
                <GridPane hgap="10" vgap="8">
                    <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
                    <Label text="API Key:" style="-fx-text-fill: #ccc;" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <TextField fx:id="apiKeyField" promptText="AIzaSy..."
                               style="-fx-background-color: #1a1a2e; -fx-text-fill: white; -fx-border-color: #444;"
                               GridPane.columnIndex="1" GridPane.rowIndex="0" GridPane.hgrow="ALWAYS"/>
                    <Label text="Modelo:" style="-fx-text-fill: #ccc;" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <ComboBox fx:id="modelCombo"
                              style="-fx-background-color: #1a1a2e; -fx-text-fill: white;"
                              GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                    <columnConstraints>
                        <ColumnConstraints minWidth="80"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                    </columnConstraints>
                </GridPane>
            </TitledPane>

            <!-- Folder Selector -->
            <TitledPane text="Carpeta de JDownloader" collapsible="false"
                        style="-fx-text-fill: white; -fx-base: #0f3460;">
                <VBox spacing="8">
                    <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Button text="Seleccionar Carpeta" onAction="#onSelectFolder"
                                style="-fx-background-color: #e94560; -fx-text-fill: white; -fx-font-weight: bold;"/>
                        <Label fx:id="folderLabel" text="Ninguna carpeta seleccionada"
                               style="-fx-text-fill: #888; -fx-font-size: 11;"/>
                    </HBox>
                    <ListView fx:id="pageList" prefHeight="140"
                              style="-fx-background-color: #1a1a2e; -fx-text-fill: white; -fx-border-color: #333;"/>
                </VBox>
            </TitledPane>

            <!-- Actions -->
            <HBox spacing="12" alignment="CENTER">
                <Button fx:id="translateBtn" text="Traducir Todo y Exportar PDF"
                        onAction="#onTranslate" disable="true"
                        prefWidth="260" prefHeight="40"
                        style="-fx-background-color: #4ecca3; -fx-text-fill: #1a1a2e; -fx-font-weight: bold; -fx-font-size: 14;"/>
            </HBox>

            <!-- Progress -->
            <VBox spacing="6">
                <ProgressBar fx:id="progressBar" progress="0" maxWidth="Infinity"/>
                <Label fx:id="statusLabel" text="Selecciona una carpeta para comenzar."
                       style="-fx-text-fill: #888; -fx-font-size: 11;"/>
            </VBox>

        </VBox>
    </center>

</BorderPane>
